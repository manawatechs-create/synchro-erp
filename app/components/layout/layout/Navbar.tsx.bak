'use client'

import { useState, useEffect, useRef } from 'react'
import { useRouter, usePathname } from 'next/navigation'

export default function Navbar() {
  const router = useRouter()
  const pathname = usePathname()
  const [user, setUser] = useState<any>(null)
  const [notifications, setNotifications] = useState<any[]>([])
  const [activeMenu, setActiveMenu] = useState<string | null>(null)
  const [showUserMenu, setShowUserMenu] = useState(false)
  const [scrolled, setScrolled] = useState(false)
  const [searchQuery, setSearchQuery] = useState('')
  const [showSearch, setShowSearch] = useState(false)
  const menuRef = useRef<HTMLDivElement>(null)
  const timeoutRef = useRef<NodeJS.Timeout | null>(null)

  useEffect(() => {
    const userData = localStorage.getItem('user')
    if (userData) setUser(JSON.parse(userData))
    fetchNotifications()

    const handleScroll = () => setScrolled(window.scrollY > 10)
    window.addEventListener('scroll', handleScroll)
    
    // Fermer les menus si on clique ailleurs
    const handleClickOutside = (e: MouseEvent) => {
      if (menuRef.current && !menuRef.current.contains(e.target as Node)) {
        setActiveMenu(null)
      }
    }
    document.addEventListener('mousedown', handleClickOutside)
    
    return () => {
      window.removeEventListener('scroll', handleScroll)
      document.removeEventListener('mousedown', handleClickOutside)
    }
  }, [])

  const fetchNotifications = async () => {
    try {
      const token = localStorage.getItem('token')
      const response = await fetch('/api/notifications', {
        headers: { 'Authorization': `Bearer ${token}` }
      })
      if (response.ok) {
        const data = await response.json()
        setNotifications(data.filter((n: any) => !n.lu).slice(0, 10))
      }
    } catch (error) {}
  }

  const handleLogout = () => {
    localStorage.removeItem('token')
    localStorage.removeItem('user')
    router.push('/login')
  }

  // OUVERTURE/FERMETURE AU CLIC
  const handleMenuClick = (menuId: string) => {
    if (activeMenu === menuId) {
      setActiveMenu(null) // Fermer si déjà ouvert
    } else {
      setActiveMenu(menuId) // Ouvrir le menu cliqué
    }
  }

  // Fermeture après délai au survol
  const handleMouseEnter = (menuId: string) => {
    if (timeoutRef.current) clearTimeout(timeoutRef.current)
    setActiveMenu(menuId)
  }

  const handleMouseLeave = () => {
    timeoutRef.current = setTimeout(() => {
      // Ne pas fermer si on est en train de cliquer
    }, 300)
  }

  const isActive = (path: string) => pathname === path
  
  const isParentActive = (paths: string[]) => paths.some(p => pathname?.startsWith(p))

  const megaMenu = {
    gestion: {
      title: 'Gestion',
      icon: '📦',
      paths: ['/dashboard/produits', '/dashboard/ventes', '/dashboard/achats', '/dashboard/membres'],
      columns: [
        {
          title: 'Catalogue',
          items: [
            { icon: '📦', label: 'Produits', desc: 'Gérer le catalogue', path: '/dashboard/produits', color: '#3b82f6' },
            { icon: '📋', label: 'Catégories', desc: 'Organiser les produits', path: '/dashboard/produits', color: '#6366f1' },
          ]
        },
        {
          title: 'Transactions',
          items: [
            { icon: '💰', label: 'Ventes', desc: 'Suivre les ventes', path: '/dashboard/ventes', color: '#10b981' },
            { icon: '🛒', label: 'Achats', desc: 'Gérer les achats', path: '/dashboard/achats', color: '#f59e0b' },
          ]
        },
        {
          title: 'Relations',
          items: [
            { icon: '👥', label: 'Membres', desc: 'Annuaire complet', path: '/dashboard/membres', color: '#8b5cf6' },
          ]
        }
      ]
    },
    finance: {
      title: 'Finance',
      icon: '💳',
      paths: ['/dashboard/factures', '/dashboard/accounting', '/dashboard/rapports'],
      columns: [
        {
          title: 'Facturation',
          items: [
            { icon: '🧾', label: 'Factures', desc: 'Générer des factures PDF', path: '/dashboard/factures', color: '#ef4444' },
            { icon: '📄', label: 'Devis', desc: 'Créer des devis', path: '/dashboard/factures', color: '#f97316' },
          ]
        },
        {
          title: 'Comptabilité',
          items: [
            { icon: '💳', label: 'Comptes', desc: 'Bilan & résultat', path: '/dashboard/accounting', color: '#06b6d4' },
            { icon: '📊', label: 'Rapports', desc: 'Analyses financières', path: '/dashboard/rapports', color: '#84cc16' },
          ]
        }
      ]
    },
    intelligence: {
      title: 'Intelligence',
      icon: '🤖',
      paths: ['/dashboard/analytics', '/dashboard/ai-assistant'],
      columns: [
        {
          title: 'Analyse',
          items: [
            { icon: '📈', label: 'Analytics', desc: 'KPIs & graphiques', path: '/dashboard/analytics', color: '#a855f7' },
            { icon: '🤖', label: 'IA Assistant', desc: 'Prédictions IA', path: '/dashboard/ai-assistant', color: '#7c3aed' },
          ]
        }
      ]
    },
    outils: {
      title: 'Outils',
      icon: '🔧',
      paths: ['/dashboard/calendar', '/dashboard/documents', '/dashboard/loyalty'],
      columns: [
        {
          title: 'Planning',
          items: [
            { icon: '📅', label: 'Calendrier', desc: 'Planning agricole', path: '/dashboard/calendar', color: '#14b8a6' },
          ]
        },
        {
          title: 'Ressources',
          items: [
            { icon: '📸', label: 'Documents', desc: 'Gestion fichiers', path: '/dashboard/documents', color: '#f97316' },
            { icon: '🏆', label: 'Fidélité', desc: 'Programme points', path: '/dashboard/loyalty', color: '#eab308' },
          ]
        }
      ]
    }
  }

  return (
    <div ref={menuRef}>
      <nav style={{
        position: 'sticky',
        top: 0,
        zIndex: 1000,
        background: scrolled 
          ? 'rgba(15, 23, 42, 0.98)' 
          : '#0f172a',
        backdropFilter: 'blur(20px)',
        borderBottom: '1px solid rgba(255,255,255,0.06)',
        transition: 'all 0.3s ease',
        boxShadow: scrolled 
          ? '0 4px 30px rgba(0,0,0,0.4)' 
          : 'none',
        fontFamily: 'system-ui, -apple-system, sans-serif'
      }}>
        {/* Barre supérieure - Logo + Recherche + Profil */}
        <div style={{
          maxWidth: '1440px',
          margin: '0 auto',
          padding: '0 24px',
          height: '60px',
          display: 'flex',
          alignItems: 'center',
          justifyContent: 'space-between',
          gap: '20px'
        }}>
          {/* Logo */}
          <div 
            onClick={() => router.push('/dashboard')}
            style={{ 
              display: 'flex', 
              alignItems: 'center', 
              gap: '14px', 
              cursor: 'pointer',
              flexShrink: 0
            }}
          >
            <div style={{
              width: '42px',
              height: '42px',
              borderRadius: '12px',
              background: 'linear-gradient(135deg, #22c55e, #16a34a)',
              display: 'flex',
              alignItems: 'center',
              justifyContent: 'center',
              fontSize: '22px',
              boxShadow: '0 4px 15px rgba(34,197,94,0.3)'
            }}>
              🌱
            </div>
            <div>
              <h1 style={{ fontSize: '16px', fontWeight: '700', color: '#f1f5f9', margin: 0 }}>
                Coopérative Agricole
              </h1>
              <p style={{ fontSize: '10px', color: '#64748b', margin: 0, fontWeight: '600', letterSpacing: '1px' }}>
                GESTION INTÉGRÉE
              </p>
            </div>
          </div>

          {/* Recherche rapide */}
          <div style={{ flex: '0 1 350px', position: 'relative' }}>
            <input
              type="text"
              placeholder="🔍 Rechercher..."
              value={searchQuery}
              onChange={(e) => setSearchQuery(e.target.value)}
              onFocus={() => setShowSearch(true)}
              onBlur={() => setShowSearch(false)}
              style={{
                width: '100%',
                height: '40px',
                padding: '0 16px',
                backgroundColor: 'rgba(255,255,255,0.05)',
                border: showSearch ? '1px solid rgba(34,197,94,0.4)' : '1px solid rgba(255,255,255,0.08)',
                borderRadius: '10px',
                color: '#f1f5f9',
                fontSize: '13px',
                outline: 'none',
                transition: 'all 0.3s',
                boxSizing: 'border-box'
              }}
            />
          </div>

          {/* Notifications + Profil */}
          <div style={{ display: 'flex', alignItems: 'center', gap: '8px', flexShrink: 0 }}>
            {/* Notification bell */}
            <button
              onClick={() => router.push('/dashboard/notifications')}
              style={{
                width: '40px',
                height: '40px',
                borderRadius: '10px',
                backgroundColor: 'rgba(255,255,255,0.04)',
                border: '1px solid rgba(255,255,255,0.06)',
                cursor: 'pointer',
                color: '#94a3b8',
                display: 'flex',
                alignItems: 'center',
                justifyContent: 'center',
                position: 'relative',
                fontSize: '18px',
                transition: 'all 0.2s'
              }}
              onMouseEnter={(e) => { e.currentTarget.style.backgroundColor = 'rgba(255,255,255,0.08)'; e.currentTarget.style.color = '#f1f5f9' }}
              onMouseLeave={(e) => { e.currentTarget.style.backgroundColor = 'rgba(255,255,255,0.04)'; e.currentTarget.style.color = '#94a3b8' }}
            >
              🔔
              {notifications.length > 0 && (
                <span style={{
                  position: 'absolute',
                  top: '-4px',
                  right: '-4px',
                  minWidth: '20px',
                  height: '20px',
                  borderRadius: '10px',
                  backgroundColor: '#ef4444',
                  color: 'white',
                  fontSize: '11px',
                  fontWeight: '700',
                  display: 'flex',
                  alignItems: 'center',
                  justifyContent: 'center',
                  boxShadow: '0 2px 8px rgba(239,68,68,0.5)'
                }}>
                  {notifications.length}
                </span>
              )}
            </button>

            {/* Profil utilisateur */}
            <div style={{ position: 'relative' }}>
              <button
                onClick={() => setShowUserMenu(!showUserMenu)}
                style={{
                  height: '40px',
                  padding: '0 14px',
                  borderRadius: '10px',
                  backgroundColor: showUserMenu ? 'rgba(255,255,255,0.1)' : 'rgba(255,255,255,0.04)',
                  border: '1px solid rgba(255,255,255,0.06)',
                  cursor: 'pointer',
                  color: '#f1f5f9',
                  display: 'flex',
                  alignItems: 'center',
                  gap: '10px',
                  transition: 'all 0.2s',
                  fontSize: '13px',
                  fontWeight: '600'
                }}
              >
                <div style={{
                  width: '28px',
                  height: '28px',
                  borderRadius: '8px',
                  background: 'linear-gradient(135deg, #22c55e, #16a34a)',
                  display: 'flex',
                  alignItems: 'center',
                  justifyContent: 'center',
                  fontSize: '12px',
                  fontWeight: '700',
                  color: 'white'
                }}>
                  {user?.prenom?.charAt(0)}{user?.nom?.charAt(0)}
                </div>
                {user?.prenom} {user?.nom}
                <span style={{ fontSize: '10px', opacity: 0.5 }}>{showUserMenu ? '▲' : '▼'}</span>
              </button>

              {/* Dropdown utilisateur */}
              {showUserMenu && (
                <>
                  <div 
                    style={{ position: 'fixed', inset: 0, zIndex: 998 }} 
                    onClick={() => setShowUserMenu(false)} 
                  />
                  <div style={{
                    position: 'absolute',
                    top: 'calc(100% + 8px)',
                    right: 0,
                    width: '260px',
                    backgroundColor: '#1e293b',
                    border: '1px solid rgba(255,255,255,0.1)',
                    borderRadius: '14px',
                    padding: '8px',
                    boxShadow: '0 20px 60px rgba(0,0,0,0.6)',
                    zIndex: 999,
                    animation: 'fadeIn 0.15s ease'
                  }}>
                    <div style={{ padding: '16px', borderBottom: '1px solid rgba(255,255,255,0.06)', marginBottom: '4px' }}>
                      <p style={{ fontWeight: '700', fontSize: '14px', color: '#f1f5f9', margin: '0 0 4px 0' }}>
                        {user?.prenom} {user?.nom}
                      </p>
                      <p style={{ fontSize: '12px', color: '#64748b', margin: 0 }}>{user?.email}</p>
                      <span style={{
                        display: 'inline-block',
                        marginTop: '8px',
                        padding: '3px 10px',
                        borderRadius: '6px',
                        backgroundColor: 'rgba(34,197,94,0.15)',
                        color: '#4ade80',
                        fontSize: '11px',
                        fontWeight: '600',
                        textTransform: 'uppercase',
                        letterSpacing: '0.5px'
                      }}>
                        {user?.role}
                      </span>
                    </div>
                    <button onClick={() => { router.push('/dashboard'); setShowUserMenu(false); }}
                      style={dropdownItemStyle}>
                      📊 Dashboard
                    </button>
                    <button onClick={() => { router.push('/dashboard/parametres'); setShowUserMenu(false); }}
                      style={dropdownItemStyle}>
                      ⚙️ Paramètres
                    </button>
                    <div style={{ height: '1px', backgroundColor: 'rgba(255,255,255,0.06)', margin: '4px 0' }} />
                    <button onClick={() => { handleLogout(); setShowUserMenu(false); }}
                      style={{ ...dropdownItemStyle, color: '#fca5a5' }}>
                      🚪 Déconnexion
                    </button>
                  </div>
                </>
              )}
            </div>
          </div>
        </div>

        {/* Barre de navigation - MENUS PRINCIPAUX */}
        <div style={{
          borderTop: '1px solid rgba(255,255,255,0.04)',
          maxWidth: '1440px',
          margin: '0 auto',
          padding: '0 24px',
          display: 'flex',
          alignItems: 'center',
          gap: '2px',
          height: '46px',
          overflowX: 'auto'
        }}>
          {/* Bouton Dashboard */}
          <button
            onClick={() => router.push('/dashboard')}
            style={{
              ...menuButtonStyle,
              backgroundColor: isActive('/dashboard') ? 'rgba(34,197,94,0.2)' : 'transparent',
              color: isActive('/dashboard') ? '#4ade80' : '#94a3b8',
              fontWeight: isActive('/dashboard') ? '600' : '400'
            }}
          >
            📊 Dashboard
          </button>

          {/* Menus avec sous-menus */}
          {Object.entries(megaMenu).map(([key, menu]) => {
            const isOpen = activeMenu === key
            const isActiveMenu = isParentActive(menu.paths)
            
            return (
              <div 
                key={key} 
                style={{ position: 'relative' }}
                onMouseEnter={() => handleMouseEnter(key)}
                onMouseLeave={handleMouseLeave}
              >
                <button
                  onClick={(e) => {
                    e.stopPropagation()
                    handleMenuClick(key)
                  }}
                  style={{
                    ...menuButtonStyle,
                    backgroundColor: isOpen ? 'rgba(255,255,255,0.1)' : isActiveMenu ? 'rgba(34,197,94,0.15)' : 'transparent',
                    color: isOpen ? '#f1f5f9' : isActiveMenu ? '#4ade80' : '#94a3b8',
                    fontWeight: isOpen || isActiveMenu ? '600' : '400'
                  }}
                >
                  <span style={{ fontSize: '16px' }}>{menu.icon}</span>
                  {menu.title}
                  <span style={{ 
                    fontSize: '10px', 
                    marginLeft: '4px',
                    transition: 'transform 0.2s',
                    transform: isOpen ? 'rotate(180deg)' : 'rotate(0deg)',
                    opacity: 0.5
                  }}>
                    ▼
                  </span>
                </button>

                {/* SOUS-MENU DÉROULANT */}
                {isOpen && (
                  <>
                    {/* Overlay invisible pour fermer au clic extérieur */}
                    <div 
                      style={{ 
                        position: 'fixed', 
                        inset: 0, 
                        zIndex: 997,
                        cursor: 'default'
                      }} 
                      onClick={() => setActiveMenu(null)} 
                    />
                    
                    {/* Mega Menu */}
                    <div style={{
                      position: 'absolute',
                      top: '100%',
                      left: '50%',
                      transform: 'translateX(-50%)',
                      marginTop: '2px',
                      backgroundColor: '#1e293b',
                      border: '1px solid rgba(255,255,255,0.1)',
                      borderRadius: '14px',
                      padding: '20px',
                      boxShadow: '0 20px 60px rgba(0,0,0,0.6)',
                      zIndex: 998,
                      display: 'flex',
                      gap: '24px',
                      minWidth: '550px',
                      animation: 'fadeIn 0.15s ease'
                    }}>
                      {menu.columns.map((column, colIndex) => (
                        <div key={colIndex} style={{ flex: 1 }}>
                          <h4 style={{
                            fontSize: '10px',
                            fontWeight: '700',
                            textTransform: 'uppercase',
                            letterSpacing: '1.5px',
                            color: '#475569',
                            marginBottom: '10px',
                            paddingLeft: '8px'
                          }}>
                            {column.title}
                          </h4>
                          <div style={{ display: 'flex', flexDirection: 'column', gap: '2px' }}>
                            {column.items.map((item, itemIndex) => (
                              <button
                                key={itemIndex}
                                onClick={() => {
                                  router.push(item.path)
                                  setActiveMenu(null)
                                }}
                                style={{
                                  width: '100%',
                                  padding: '12px',
                                  textAlign: 'left',
                                  backgroundColor: isActive(item.path) ? 'rgba(255,255,255,0.06)' : 'transparent',
                                  border: 'none',
                                  borderRadius: '10px',
                                  cursor: 'pointer',
                                  display: 'flex',
                                  alignItems: 'center',
                                  gap: '12px',
                                  transition: 'all 0.15s',
                                  color: isActive(item.path) ? '#f1f5f9' : '#94a3b8'
                                }}
                                onMouseEnter={(e) => {
                                  e.currentTarget.style.backgroundColor = 'rgba(255,255,255,0.08)'
                                  e.currentTarget.style.color = '#f1f5f9'
                                }}
                                onMouseLeave={(e) => {
                                  if (!isActive(item.path)) {
                                    e.currentTarget.style.backgroundColor = 'transparent'
                                    e.currentTarget.style.color = '#94a3b8'
                                  }
                                }}
                              >
                                <span style={{ fontSize: '20px', width: '32px', textAlign: 'center' }}>
                                  {item.icon}
                                </span>
                                <div style={{ flex: 1 }}>
                                  <div style={{ display: 'flex', alignItems: 'center', gap: '8px' }}>
                                    <span style={{ fontSize: '14px', fontWeight: '600' }}>{item.label}</span>
                                    {isActive(item.path) && (
                                      <span style={{
                                        width: '6px',
                                        height: '6px',
                                        borderRadius: '50%',
                                        backgroundColor: item.color
                                      }}></span>
                                    )}
                                  </div>
                                  <span style={{ fontSize: '11px', color: '#64748b', marginTop: '2px', display: 'block' }}>
                                    {item.desc}
                                  </span>
                                </div>
                              </button>
                            ))}
                          </div>
                        </div>
                      ))}
                    </div>
                  </>
                )}
              </div>
            )
          })}

          {/* Notifications (droite) */}
          <button
            onClick={() => router.push('/dashboard/notifications')}
            style={{
              ...menuButtonStyle,
              backgroundColor: isActive('/dashboard/notifications') ? 'rgba(239,68,68,0.15)' : 'transparent',
              color: isActive('/dashboard/notifications') ? '#f87171' : '#94a3b8',
              marginLeft: 'auto'
            }}
          >
            🔔 Notifications
            {notifications.length > 0 && (
              <span style={{ color: '#f87171', fontWeight: '700', fontSize: '12px' }}>
                ({notifications.length})
              </span>
            )}
          </button>
        </div>
      </nav>

      <style jsx global>{`
        @keyframes fadeIn {
          from { opacity: 0; transform: translateX(-50%) translateY(-8px); }
          to { opacity: 1; transform: translateX(-50%) translateY(0); }
        }
        @keyframes slideDown {
          from { opacity: 0; transform: translateY(-10px); }
          to { opacity: 1; transform: translateY(0); }
        }
      `}</style>
    </div>
  )
}

// Styles réutilisables
const menuButtonStyle: React.CSSProperties = {
  padding: '8px 16px',
  border: 'none',
  borderRadius: '10px',
  cursor: 'pointer',
  fontSize: '13px',
  display: 'flex',
  alignItems: 'center',
  gap: '6px',
  whiteSpace: 'nowrap',
  transition: 'all 0.15s',
  height: '36px',
  background: 'transparent',
  position: 'relative'
}

const dropdownItemStyle: React.CSSProperties = {
  width: '100%',
  padding: '10px 14px',
  textAlign: 'left',
  backgroundColor: 'transparent',
  border: 'none',
  borderRadius: '10px',
  cursor: 'pointer',
  color: '#94a3b8',
  fontSize: '13px',
  display: 'flex',
  alignItems: 'center',
  gap: '10px',
  fontWeight: '500',
  transition: 'all 0.15s'
}
